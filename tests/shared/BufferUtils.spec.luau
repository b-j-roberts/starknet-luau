--!strict
local BufferUtils = require("../../src/shared/BufferUtils")

describe("BufferUtils", function()
	describe("bufferToHex", function()
		it("converts empty buffer to empty string", function()
			local buf = buffer.create(0)
			expect(BufferUtils.bufferToHex(buf)):toBe("")
		end)

		it("converts single byte", function()
			local buf = buffer.create(1)
			buffer.writeu8(buf, 0, 0xAB)
			expect(BufferUtils.bufferToHex(buf)):toBe("ab")
		end)

		it("converts multi-byte buffer", function()
			local buf = buffer.create(4)
			buffer.writeu8(buf, 0, 0xDE)
			buffer.writeu8(buf, 1, 0xAD)
			buffer.writeu8(buf, 2, 0xBE)
			buffer.writeu8(buf, 3, 0xEF)
			expect(BufferUtils.bufferToHex(buf)):toBe("deadbeef")
		end)

		it("handles zero bytes", function()
			local buf = buffer.create(2)
			buffer.writeu8(buf, 0, 0x00)
			buffer.writeu8(buf, 1, 0x01)
			expect(BufferUtils.bufferToHex(buf)):toBe("0001")
		end)

		it("handles all-zero buffer", function()
			local buf = buffer.create(3)
			expect(BufferUtils.bufferToHex(buf)):toBe("000000")
		end)
	end)

	describe("concatBuffers", function()
		it("concatenates two buffers", function()
			local a = buffer.create(2)
			buffer.writeu8(a, 0, 0xAA)
			buffer.writeu8(a, 1, 0xBB)
			local b = buffer.create(2)
			buffer.writeu8(b, 0, 0xCC)
			buffer.writeu8(b, 1, 0xDD)
			local result = BufferUtils.concatBuffers(a, b)
			expect(buffer.len(result)):toBe(4)
			expect(buffer.readu8(result, 0)):toBe(0xAA)
			expect(buffer.readu8(result, 1)):toBe(0xBB)
			expect(buffer.readu8(result, 2)):toBe(0xCC)
			expect(buffer.readu8(result, 3)):toBe(0xDD)
		end)

		it("concatenates three buffers", function()
			local a = buffer.create(1)
			buffer.writeu8(a, 0, 0x01)
			local b = buffer.create(1)
			buffer.writeu8(b, 0, 0x02)
			local c = buffer.create(1)
			buffer.writeu8(c, 0, 0x03)
			local result = BufferUtils.concatBuffers(a, b, c)
			expect(buffer.len(result)):toBe(3)
			expect(buffer.readu8(result, 0)):toBe(0x01)
			expect(buffer.readu8(result, 1)):toBe(0x02)
			expect(buffer.readu8(result, 2)):toBe(0x03)
		end)

		it("handles empty buffers", function()
			local a = buffer.create(0)
			local b = buffer.create(2)
			buffer.writeu8(b, 0, 0xFF)
			buffer.writeu8(b, 1, 0xFE)
			local result = BufferUtils.concatBuffers(a, b)
			expect(buffer.len(result)):toBe(2)
			expect(buffer.readu8(result, 0)):toBe(0xFF)
		end)
	end)

	describe("singleByte", function()
		it("creates a 1-byte buffer with given value", function()
			local buf = BufferUtils.singleByte(0x42)
			expect(buffer.len(buf)):toBe(1)
			expect(buffer.readu8(buf, 0)):toBe(0x42)
		end)

		it("creates zero byte", function()
			local buf = BufferUtils.singleByte(0x00)
			expect(buffer.len(buf)):toBe(1)
			expect(buffer.readu8(buf, 0)):toBe(0x00)
		end)

		it("creates max byte", function()
			local buf = BufferUtils.singleByte(0xFF)
			expect(buffer.len(buf)):toBe(1)
			expect(buffer.readu8(buf, 0)):toBe(0xFF)
		end)
	end)

	describe("readBE32", function()
		it("reads big-endian 32-bit value", function()
			local buf = buffer.create(4)
			buffer.writeu8(buf, 0, 0xDE)
			buffer.writeu8(buf, 1, 0xAD)
			buffer.writeu8(buf, 2, 0xBE)
			buffer.writeu8(buf, 3, 0xEF)
			expect(BufferUtils.readBE32(buf, 0)):toBe(0xDEADBEEF)
		end)

		it("reads from offset", function()
			local buf = buffer.create(8)
			buffer.writeu8(buf, 4, 0x00)
			buffer.writeu8(buf, 5, 0x00)
			buffer.writeu8(buf, 6, 0x00)
			buffer.writeu8(buf, 7, 0x01)
			expect(BufferUtils.readBE32(buf, 4)):toBe(1)
		end)

		it("reads zero", function()
			local buf = buffer.create(4)
			expect(BufferUtils.readBE32(buf, 0)):toBe(0)
		end)
	end)

	describe("writeBE32", function()
		it("writes big-endian 32-bit value", function()
			local buf = buffer.create(4)
			BufferUtils.writeBE32(buf, 0, 0xDEADBEEF)
			expect(buffer.readu8(buf, 0)):toBe(0xDE)
			expect(buffer.readu8(buf, 1)):toBe(0xAD)
			expect(buffer.readu8(buf, 2)):toBe(0xBE)
			expect(buffer.readu8(buf, 3)):toBe(0xEF)
		end)

		it("writes at offset", function()
			local buf = buffer.create(8)
			BufferUtils.writeBE32(buf, 4, 0x01020304)
			expect(buffer.readu8(buf, 4)):toBe(0x01)
			expect(buffer.readu8(buf, 5)):toBe(0x02)
			expect(buffer.readu8(buf, 6)):toBe(0x03)
			expect(buffer.readu8(buf, 7)):toBe(0x04)
		end)

		it("round-trips with readBE32", function()
			local buf = buffer.create(4)
			BufferUtils.writeBE32(buf, 0, 0x12345678)
			expect(BufferUtils.readBE32(buf, 0)):toBe(0x12345678)
		end)

		it("writes zero", function()
			local buf = buffer.create(4)
			BufferUtils.writeBE32(buf, 0, 0)
			expect(BufferUtils.readBE32(buf, 0)):toBe(0)
		end)
	end)
end)
